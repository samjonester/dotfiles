#!/usr/bin/env bash
# workspace (aliased as `lfg`) - create or reattach tmux sessions
#
# Usage:
#   lfg                              (pick session or create new)
#   lfg -n <name> ["prompt"]         (attach/create session by name)
#   lfg ["prompt"]                   (inside tmux: window picker в†’ dir в†’ pi)
#   lfg --pane ["prompt"]            (inside tmux: skip name в†’ dir в†’ pi)
#
# Behavior depends on context:
#   Outside tmux вЂ” session picker flow (or -n to skip it)
#   Inside tmux  вЂ” window picker (select existing or name new), then dir в†’ pi
#   --pane       вЂ” pane mode: skip the name step entirely
#
# Requires: fzf, tmux, zoxide

set -euo pipefail

# Set kitty tab title via OSC escape sequence
set_tab_title() {
    printf '\033]2;%s\007' "$1"
}

# в”Ђв”Ђв”Ђ Session picker (outside tmux) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

_lfg_list_sessions() {
    tmux list-sessions -F '#{session_name}|#{?session_attached,attached,detached}|#{session_windows} windows' 2>/dev/null | while IFS='|' read -r name status windows; do
        [[ -z "$name" ]] && continue
        local icon="в—‹"
        [[ "$status" == "attached" ]] && icon="в—Џ"
        echo "${icon} ${name}  (${status}, ${windows})"
    done
}

pick_session() {
    local fzf_input self
    fzf_input=$(_lfg_list_sessions)
    self="$0"

    local fzf_exit=0 result
    result=$(printf '%s' "$fzf_input" | fzf \
        --print-query \
        --exact \
        --prompt="session вќЇ " \
        --header="Enter: select or type new  в”‚  Del: kill session" \
        --header-first \
        --height=~50% \
        --reverse \
        --no-info \
        --bind "del:execute-silent($self --kill-session {})+reload($self --list-sessions)" \
        2>/dev/null) || fzf_exit=$?

    [[ $fzf_exit -ge 2 ]] && return 1

    local query selected
    query=$(head -1 <<< "$result")
    selected=$(sed -n '2p' <<< "$result")

    if [[ "$selected" == [в—Џв—‹]* ]]; then
        echo "$selected" | sed 's/^[в—Џв—‹] //; s/  (.*//'
        return 0
    fi

    if [[ -n "$query" ]]; then
        echo "$query"
        return 0
    fi

    return 1
}

# в”Ђв”Ђв”Ђ Window picker (inside tmux) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

pick_window() {
    # List windows in the current tmux session
    local windows
    windows=$(tmux list-windows -F '#{window_index}|#{window_name}|#{window_active}' 2>/dev/null)

    local fzf_input=""
    while IFS='|' read -r idx wname active; do
        [[ -z "$idx" ]] && continue
        local icon="в—‹"
        [[ "$active" == "1" ]] && icon="в—Џ"
        fzf_input+="${icon} ${wname}  (${idx})"$'\n'
    done <<< "$windows"

    local fzf_exit=0 result
    result=$(printf '%s' "$fzf_input" | fzf \
        --print-query \
        --exact \
        --prompt="window вќЇ " \
        --header="Select window or type new name" \
        --header-first \
        --height=~50% \
        --reverse \
        --no-info \
        2>/dev/null) || fzf_exit=$?

    [[ $fzf_exit -ge 2 ]] && return 1

    local query selected
    query=$(head -1 <<< "$result")
    selected=$(sed -n '2p' <<< "$result")

    # User selected an existing window from the list в†’ navigate
    if [[ "$selected" == [в—Џв—‹]* ]]; then
        local win_idx
        win_idx=$(echo "$selected" | sed 's/.*(\([0-9]*\))/\1/')
        tmux select-window -t ":${win_idx}"
        return 2  # Signal: navigated to existing window
    fi

    # User typed a name вЂ” check if it matches an existing window
    if [[ -n "$query" ]]; then
        local match_idx
        match_idx=$(tmux list-windows -F '#{window_name}|#{window_index}' 2>/dev/null \
            | grep -i "^${query}|" | head -1 | cut -d'|' -f2)
        if [[ -n "$match_idx" ]]; then
            tmux select-window -t ":${match_idx}"
            return 2  # Signal: navigated to existing window
        fi
        echo "$query"
        return 0
    fi

    return 1
}

# в”Ђв”Ђв”Ђ Directory picker в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

pick_directory() {
    local result
    result=$(zoxide query -l 2>/dev/null | fzf \
        --print-query \
        --prompt="dir вќЇ " \
        --header="Type path or pick from history" \
        --header-first \
        --height=~50% \
        --reverse \
        --no-info \
        --scheme=path \
        2>/dev/null) || true

    local query selected
    query=$(echo "$result" | head -1)
    selected=$(echo "$result" | tail -1)

    if [[ -n "$selected" && "$selected" != "$query" ]]; then
        echo "$selected"
        return 0
    fi

    if [[ -n "$query" ]]; then
        local expanded="${query/#\~/$HOME}"
        if [[ -d "$expanded" ]]; then
            echo "$expanded"
            return 0
        fi
        zoxide query -- "$query" 2>/dev/null && return 0
    fi

    return 1
}

# в”Ђв”Ђв”Ђ Enter tmux session (outside tmux flow) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enter_session() {
    local session_name="$1"
    local dir="${2:-}"
    local prompt="${3:-}"

    set_tab_title "$session_name"

    local pi_cmd="TMPDIR=$HOME/.pi/tmp devx pi"
    [[ -n "$prompt" ]] && pi_cmd="$pi_cmd $(printf '%q' "$prompt")"

    # Inside tmux already в†’ switch client
    if [[ -n "${TMUX:-}" ]]; then
        if ! tmux has-session -t "=$session_name" 2>/dev/null; then
            tmux new-session -d -s "$session_name" -c "${dir:-$HOME}"
            tmux send-keys -t "=$session_name:" "$pi_cmd" Enter
        fi
        exec tmux switch-client -t "=$session_name"
    fi

    # Existing session в†’ attach
    if tmux has-session -t "=$session_name" 2>/dev/null; then
        exec tmux attach-session -t "=$session_name"
    fi

    # New session
    tmux new-session -d -s "$session_name" -c "${dir:-$HOME}"
    tmux send-keys -t "=$session_name:" "$pi_cmd" Enter
    exec tmux attach-session -t "=$session_name"
}

# в”Ђв”Ђв”Ђ Exec pi in current shell (inside tmux) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

exec_pi() {
    local prompt="${1:-}"
    local dir

    dir=$(pick_directory) || exit 0

    cd "$dir"
    local -a pi_args=("devx" "pi")
    [[ -n "$prompt" ]] && pi_args+=("$prompt")
    TMPDIR="$HOME/.pi/tmp" exec "${pi_args[@]}"
}

# в”Ђв”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

main() {
    # Internal subcommands for fzf bindings
    if [[ "${1:-}" == "--list-sessions" ]]; then
        _lfg_list_sessions
        return 0
    fi
    if [[ "${1:-}" == "--kill-session" ]]; then
        local name
        name=$(echo "${2:-}" | sed 's/^[в—Џв—‹] //; s/  (.*//')
        [[ -n "$name" ]] && tmux kill-session -t "=$name" 2>/dev/null
        return 0
    fi

    # Parse flags
    local session_name="" prompt="" pane_mode=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n|--name)
                session_name="${2:-}"
                shift 2
                ;;
            --pane)
                pane_mode=true
                shift
                ;;
            *)
                prompt="$1"
                shift
                ;;
        esac
    done

    # в”Ђв”Ђ Inside tmux в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    if [[ -n "${TMUX:-}" ]]; then

        # Pane mode: skip name, go straight to dir в†’ pi
        if [[ "$pane_mode" == true ]]; then
            exec_pi "$prompt"
            return 0
        fi

        # Window mode: pick or create window, then dir в†’ pi
        local pick_exit=0 window_name=""
        window_name=$(pick_window) || pick_exit=$?

        # Exit code 2 = navigated to existing window; temp window closes on exit
        [[ $pick_exit -eq 2 ]] && exit 0
        # Exit code 1 = cancelled
        [[ $pick_exit -eq 1 ]] && exit 0

        # Got a new window name вЂ” rename current window
        [[ -n "$window_name" ]] && tmux rename-window "$window_name"

        exec_pi "$prompt"
        return 0
    fi

    # в”Ђв”Ђ Outside tmux в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    if [[ -z "$session_name" ]]; then
        session_name=$(pick_session) || exit 0
    fi

    # Existing session вЂ” just attach
    if tmux has-session -t "=$session_name" 2>/dev/null; then
        enter_session "$session_name"
    fi

    # New session вЂ” pick directory
    local dir
    dir=$(pick_directory) || exit 0
    enter_session "$session_name" "$dir" "$prompt"
}

main "$@"
